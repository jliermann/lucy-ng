# Reference databases
# Keep compressed .sd.gz files, ignore decompressed .sd files (auto-generated)
data/reference/*.sd
!data/reference/*.sd.gz
# Ignore large SDF files (COCONUT ~4.5GB)
data/reference/*.sdf
# Ignore SQLite databases (generated via `lucy database build`)
data/reference/*.db
# Keep compressed database for distribution
!data/reference/*.db.gz
# Ignore zipped databases (deposited on Zenodo/Figshare, not in git)
data/reference/*.db.zip

# Benchmark results (large, generated at runtime)
tests/case-benchmark/results/
