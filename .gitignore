# Reference databases
# Keep compressed .sd.gz files, ignore decompressed .sd files (auto-generated)
data/reference/*.sd
!data/reference/*.sd.gz
# Ignore large SDF files (COCONUT ~4.5GB)
data/reference/*.sdf
# Ignore SQLite databases (generated via `lucy database build`)
data/reference/*.db
# Keep compressed database for distribution
!data/reference/*.db.gz
# Ignore zipped databases (deposited on Zenodo/Figshare, not in git)
data/reference/*.db.zip

# Benchmark results (large, generated at runtime)
tests/case-benchmark/results/

# LSD runtime debris (LSD binary writes these to the cwd on every run)
solncounter
outlsd.out
# Fragment goodlist files generated by `lucy fragment to-lsd` (kept where the agent puts them, not at repo root)
/fragment_*.lsd

# Large background PDFs — kept locally for reference, deposited elsewhere (DOI/Zenodo) not in git
background/*.pdf

# Blind-UAT answer keys — keep LOCAL only, never push (public repo).
# These map CASE datasets to their ground-truth identities / UAT outcomes.
.planning/CASE-DATASET-IDENTITIES.md
.planning/CASE-UAT-LOG.md
