;  1 = C1  180.56 Cq  COOH-carbonyl
;  2 = C2  140.84 Cq  aromat. ipso (benzyl-side)
;  3 = C3  136.96 Cq  aromat. ipso para (alpha-CH-side)
;  4 = C4  129.38 CH  aromat. equiv A -- ortho to C2
;  5 = C4  129.38 CH  aromat. equiv B -- ortho to C2
;  6 = C5  127.26 CH  aromat. equiv A -- ortho to C3
;  7 = C5  127.26 CH  aromat. equiv B -- ortho to C3
;  8 = C6   45.03 CH2 benzylic
;  9 = C7   44.90 CH  alpha to COOH
; 10 = C8   30.14 CH  aliphatic (isobutyl CH)
; 11 = C9   22.37 CH3 gem-dimethyl equiv A
; 12 = C9   22.37 CH3 gem-dimethyl equiv B
; 13 = C10  18.09 CH3 alpha-methyl
; 14 = O    carbonyl oxygen (sp2, C=O)
; 15 = O    hydroxyl oxygen (sp3, COOH-OH)

MULT 1 C 2 0     ; C1 180.56 Cq sp2 -- COOH carbonyl
MULT 2 C 2 0     ; C2 140.84 Cq sp2 -- aromat. ipso
MULT 3 C 2 0     ; C3 136.96 Cq sp2 -- aromat. ipso para
MULT 4 C 2 1     ; C4 129.38 CH sp2 -- aromat. CH equiv A
MULT 5 C 2 1     ; C4 129.38 CH sp2 -- aromat. CH equiv B
MULT 6 C 2 1     ; C5 127.26 CH sp2 -- aromat. CH equiv A
MULT 7 C 2 1     ; C5 127.26 CH sp2 -- aromat. CH equiv B
MULT 8 C 3 2     ; C6  45.03 CH2 sp3 -- benzylic
MULT 9 C 3 1     ; C7  44.90 CH  sp3 -- alpha to COOH
MULT 10 C 3 1    ; C8  30.14 CH  sp3 -- isobutyl CH
MULT 11 C 3 3    ; C9  22.37 CH3 sp3 -- gem-dimethyl equiv A
MULT 12 C 3 3    ; C9  22.37 CH3 sp3 -- gem-dimethyl equiv B
MULT 13 C 3 3    ; C10 18.09 CH3 sp3 -- alpha-methyl
MULT 14 O 2 0    ; O carbonyl (sp2, C=O)
MULT 15 O 3 1    ; O hydroxyl (sp3, COOH-OH)

HSQC 4 4         ; C4 129.38 H7.12 aromat. CH equiv A
HSQC 5 5         ; C4 129.38 H7.12 aromat. CH equiv B
HSQC 6 6         ; C5 127.26 H7.21 aromat. CH equiv A
HSQC 7 7         ; C5 127.26 H7.21 aromat. CH equiv B
